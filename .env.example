# --- Authentication ---
JWT_SECRET=       # JWT signing secret (generate with: python -c "import secrets; print(secrets.token_urlsafe(64))")
API_KEY=          # Shared key for Lambda/service calls (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")

# --- CORS ---
CORS_ORIGINS=http://localhost:3000    # Comma-separated origins

# --- URLs ---
FRONTEND_URL=http://localhost:3000
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/gmail/callback

# --- Google OAuth2 ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- OpenAI ---
OPENAI_API_KEY=

# --- Hunter.io ---
HUNTER_API_KEY=

# --- AWS ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ca-central-1
SQS_QUEUE_URL=

# --- AWS Scheduling (optional -- only needed for scheduled sends) ---
SEND_EMAIL_LAMBDA_ARN=
SCHEDULER_ROLE_ARN=
